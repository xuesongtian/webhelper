{
  "name": "jianzhan-assistant-mvp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm --parallel --filter api --filter web dev",
    "build": "pnpm --filter @jianzhan/deployer build && pnpm --filter api build && pnpm --filter web build",
    "typecheck": "pnpm --filter api typecheck && pnpm --filter web typecheck",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
